*.pyc
*.pyo

# sync_engine 백업 (검토용 임시 파일)
*.before_sync

# BL-ADMIN-LIGHTMODE — 파일 단위 백업도 자동 제외 (NEVER 룰 ②)
*._backup_*

# BL-COMMON-HEADER-UNIFY: HTML 백업 파일 (NEVER 룰 ② 백업)
*_backup_*.html
