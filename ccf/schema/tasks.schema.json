{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ccf/schema/tasks.schema.json",
  "title": "CCF Tasks Schema v2",
  "description": "Command Center Framework — Single Source of Truth for tasks",
  "type": "object",
  "required": ["version", "schema", "tasks"],
  "properties": {
    "version": { "type": "string", "const": "2.0" },
    "schema":  { "type": "string", "const": "ccf-tasks-v2" },
    "updated_at":  { "type": "string", "format": "date-time" },
    "deadline":    { "type": ["string", "null"] },
    "live_url":    { "type": "string" },
    "repo":        { "type": "string" },
    "head_commit": { "type": "string" },
    "sources":     { "type": "array", "items": { "type": "string" } },
    "stats": {
      "type": "object",
      "properties": {
        "total":             { "type": "integer", "minimum": 0 },
        "done":              { "type": "integer", "minimum": 0 },
        "in_progress":       { "type": "integer", "minimum": 0 },
        "pending":           { "type": "integer", "minimum": 0 },
        "blocked":           { "type": "integer", "minimum": 0 },
        "autonomous_ready":  { "type": "integer", "minimum": 0 }
      }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/definitions/task" }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "title", "status", "priority", "category"],
      "properties": {
        "id":        { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
        "title":     { "type": "string", "minLength": 1 },
        "category":  {
          "type": "string",
          "enum": ["infrastructure", "bug", "ux", "feature", "docs", "dev", "design", "design-system", "analytics"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "done", "blocked"]
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "size": {
          "type": ["string", "null"],
          "enum": ["small", "medium", "large", null]
        },
        "started_by": {
          "type": ["string", "null"],
          "enum": ["CEO", "STAFF", "CLAUDE", null]
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocker":      { "type": ["string", "null"] },
        "parent_task":  { "type": ["string", "null"] },
        "created_at":   { "type": "string", "format": "date-time" },
        "started_at":   { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" },
        "claude_can_auto": { "type": "boolean" },
        "autonomous": {
          "type": "object",
          "properties": {
            "can_run_alone":              { "type": "boolean" },
            "estimated_hours":            { "type": "number", "minimum": 0 },
            "requires_decisions_first":   { "type": "array", "items": { "type": "string" } }
          }
        },
        "progress": { "type": "string" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["at", "by", "action"],
            "properties": {
              "at":         { "type": "string", "format": "date-time" },
              "by":         { "type": "string" },
              "action":     { "type": "string" },
              "commit_hash": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
