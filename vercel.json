{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    },
    "api/email/**/*.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/admin-hub.html",
      "destination": "/admin-status.html",
      "permanent": true
    },
    {
      "source": "/admin-hub",
      "destination": "/admin-status.html",
      "permanent": true
    },
    {
      "source": "/_chat-logs/:path*",
      "destination": "/chat-logs/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/chat-logs/index.json",
      "destination": "/api/chat-log?slug=index"
    },
    {
      "source": "/chat-logs/:slug.md",
      "destination": "/api/chat-log?slug=:slug"
    }
  ]
}
